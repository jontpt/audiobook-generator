# ─────────────────────────────────────────────────────────────────────────────
# AI Audiobook Generator — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit the actual .env file to git!
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="AudioBook Generator API"
APP_VERSION="2.0.0"
DEBUG=false

# ── Security (REQUIRED) ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme-use-openssl-rand-hex-32

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, zero config):
DATABASE_URL=sqlite:///./storage/db.sqlite
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/audiobook

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
USE_CELERY=false          # Set to true when running with docker-compose

# ── TTS: ElevenLabs ───────────────────────────────────────────────────────────
# Get your key at: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── Background Music APIs (optional) ─────────────────────────────────────────
# Mubert: https://mubert.com/render/pricing (B2B API key)
MUBERT_API_KEY=
# Soundraw: https://soundraw.io/api_access
SOUNDRAW_API_KEY=

# ── Voice IDs (ElevenLabs) ────────────────────────────────────────────────────
DEFAULT_NARRATOR_VOICE_ID=pNInz6obpgDQGcFmaJgB
DEFAULT_MALE_VOICE_ID=VR6AewLTigWG4xSOukaG
DEFAULT_FEMALE_VOICE_ID=EXAVITQu4vr4xnSDxMaL
DEFAULT_NEUTRAL_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── CORS ──────────────────────────────────────────────────────────────────────
# For production, set to your frontend domain:
# CORS_ORIGINS=https://yourapp.onrender.com,https://yourdomain.com
CORS_ORIGINS=*

# ── Flower monitoring (docker-compose only) ───────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin
